.flex.justify-between.items-center.mb-6
  %h1.text-2xl.font-bold.text-gray-900 Creators

= turbo_frame_tag "creators_list" do
  = form_with url: creators_path, method: :get, data: { turbo_frame: "creators_list" }, class: "mb-6" do |f|
    .flex.gap-3
      = f.text_field :search, value: params[:search], placeholder: "Search by name...", class: "flex-1 rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
      = f.submit "Search", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 cursor-pointer"
      - if params[:search].present?
        = link_to "Clear", creators_path, class: "rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50"

  .bg-white.rounded-lg.border.border-gray-200.overflow-hidden
    .overflow-y-auto{ style: "height: 60vh" }
      %table.min-w-full.divide-y.divide-gray-200
        %thead.bg-gray-50.sticky.top-0
          %tr
            %th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider Name
            %th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider Email
            %th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider Content Count
            %th.px-6.py-3
        %tbody.bg-white.divide-y.divide-gray-200
          - if @creators.empty?
            %tr
              %td.px-6.py-8.text-center.text-sm.text-gray-500{ colspan: 4 } No creators found.
          - else
            - @creators.each do |creator|
              %tr.hover:bg-gray-50
                %td.px-6.py-4.text-sm.font-medium.text-gray-900= creator.name
                %td.px-6.py-4.text-sm.text-gray-500= creator.email
                %td.px-6.py-4.text-sm.text-gray-500= creator.contents_count
                %td.px-6.py-4.text-right
                  = link_to "View", creator_path(creator), class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium", data: { turbo_frame: "_top" }

  .fixed.bottom-0.left-0.right-0.bg-white.border-t.border-gray-200.py-3.z-10
    = render "shared/pagination", collection: @creators, options: { search: params[:search] }
